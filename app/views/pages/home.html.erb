<% if user_signed_in? %>
  <% content_for :title, "Today" %>
  
  <div class="px-4 pt-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-season-dark">Good <%= greeting %></h1>
        <p class="text-gray-500"><%= Date.today.strftime("%A, %B %d") %></p>
      </div>
      <div class="w-12 h-12 bg-season-green rounded-full flex items-center justify-center text-white font-bold">
        <%= current_user.email[0].upcase %>
      </div>
    </div>

    <div class="bg-gradient-to-br from-season-green to-green-700 rounded-2xl p-6 text-white mb-6 shadow-lg">
      <p class="text-sm opacity-80 mb-1">Your current phase</p>
      <h2 class="text-3xl font-bold mb-4">Spring</h2>
      <p class="text-sm opacity-90">High energy & creativity. Great for new projects!</p>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 mb-1">Cycle Day</p>
        <p class="text-2xl font-bold text-season-dark">14</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 mb-1">Next Period</p>
        <p class="text-2xl font-bold text-season-dark">14 days</p>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
      <h3 class="font-semibold text-season-dark mb-4">Today's Recommendations</h3>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-season-dark text-sm">High intensity workout</p>
            <p class="text-xs text-gray-500">Your energy is peaking today</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-season-dark text-sm">Focus on complex tasks</p>
            <p class="text-xs text-gray-500">Peak cognitive performance</p>
          </div>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <% content_for :title, "Season" %>

  <div class="min-h-screen flex flex-col bg-white">
    <div class="flex-1 flex flex-col items-center justify-center px-6 py-12">
      <%= image_tag "Season_Logo.svg", class: "w-64 max-w-xs mb-8", alt: "Season Logo" %>
      
      <h1 class="text-xl text-gray-600 font-medium text-center mb-8">Align your life with your cycle</h1>

      <div class="w-full max-w-xs space-y-3">
        <%= link_to "Get Started", new_user_registration_path, class: "block w-full bg-season-green text-white text-center py-4 rounded-xl font-semibold hover:bg-green-700 transition-colors" %>
        
        <%= link_to "Sign In", new_user_session_path, class: "block w-full bg-season-cream text-season-dark text-center py-4 rounded-xl font-semibold hover:bg-amber-100 transition-colors" %>
      </div>

      <p class="mt-8 text-xs text-gray-400 text-center">©2026 Season. All rights reserved.</p>
    </div>
  </div>
<% end %>
