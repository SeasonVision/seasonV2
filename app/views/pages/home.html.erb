<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Season</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#50715c">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.jpeg">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              season: { green: '#50715c', cream: '#ede1d4', dark: '#1a1a2e' },
              phase: { winter: '#6b7280', spring: '#10b981', summer: '#f59e0b', autumn: '#f97316' }
            }
          }
        }
      }
    </script>
    <style>
      .pb-safe { padding-bottom: env(safe-area-inset-bottom, 0); }
      * { margin: 0; padding: 0; box-sizing: border-box; }
    </style>
  </head>
  <body class="bg-white text-season-dark antialiased">
    <nav class="fixed top-0 left-0 right-0 bg-season-cream px-4 py-3 flex items-center justify-between z-50">
      <%= image_tag "icon.svg", class: "h-10 w-auto", alt: "Season" %>
      <div class="flex gap-2">
        <%= link_to "Sign In", new_user_session_path, class: "px-4 py-2 text-sm font-medium text-season-dark hover:bg-white/50 rounded-lg" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "px-4 py-2 text-sm font-medium bg-season-green text-white rounded-lg hover:bg-green-700" %>
      </div>
    </nav>

    <main class="min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-8">
      <%= image_tag "Season_Logo.svg", class: "w-72 max-w-xs mb-8", alt: "Season Logo" %>
      
      <h1 class="text-xl text-gray-600 font-medium text-center mb-8">Align your life with your cycle</h1>
      
      <div class="grid grid-cols-4 gap-3 w-full max-w-sm">
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <span class="block text-2xl font-bold text-season-dark" id="days">00</span>
          <span class="text-xs text-gray-500 uppercase tracking-wider">Days</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <span class="block text-2xl font-bold text-season-dark" id="hours">00</span>
          <span class="text-xs text-gray-500 uppercase tracking-wider">Hours</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <span class="block text-2xl font-bold text-season-dark" id="minutes">00</span>
          <span class="text-xs text-gray-500 uppercase tracking-wider">Mins</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <span class="block text-2xl font-bold text-season-dark" id="seconds">00</span>
          <span class="text-xs text-gray-500 uppercase tracking-wider">Secs</span>
        </div>
      </div>
    </main>

    <footer class="text-center py-4 text-xs text-gray-400">
      ©2026 Season. All rights reserved.
    </footer>

    <script>
      const targetDate = new Date('2026-04-06T00:00:00').getTime();
      function updateCountdown() {
        const now = new Date().getTime();
        const distance = targetDate - now;
        if (distance < 0) {
          document.getElementById('days').parentElement.innerHTML = '<span class="text-xl font-bold">We\'re Live!</span>';
          return;
        }
        document.getElementById('days').textContent = String(Math.floor(distance / (1000 * 60 * 60 * 24))).padStart(2, '0');
        document.getElementById('hours').textContent = String(Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))).padStart(2, '0');
        document.getElementById('minutes').textContent = String(Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
        document.getElementById('seconds').textContent = String(Math.floor((distance % (1000 * 60)) / 1000)).padStart(2, '0');
      }
      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </body>
</html>
