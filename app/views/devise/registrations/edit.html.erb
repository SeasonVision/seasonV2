<% content_for :title, "Account Settings" %>

<div class="min-h-screen flex flex-col">
  <nav class="fixed top-0 left-0 right-0 bg-season-cream px-4 py-3 flex items-center justify-between z-50">
    <%= link_to :back do %>
      <svg class="w-6 h-6 text-season-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <span class="font-semibold text-season-dark">Account Settings</span>
    <div class="w-6"></div>
  </nav>

  <div class="flex-1 px-6 pt-20 pb-8">
    <div class="w-full max-w-sm mx-auto">
      <h1 class="text-2xl font-bold text-season-dark mb-6">Edit Profile</h1>
      
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="text-sm text-amber-600">Waiting confirmation for: <%= resource.unconfirmed_email %></div>
        <% end %>

        <div class="pt-4 border-t border-gray-100">
          <p class="text-sm font-medium text-gray-700 mb-2">Change Password (leave blank to keep current)</p>
          
          <div class="space-y-3">
            <div>
              <%= f.label :password, class: "block text-sm text-gray-600 mb-1" %>
              <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
            </div>

            <div>
              <%= f.label :password_confirmation, class: "block text-sm text-gray-600 mb-1" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
            </div>
          </div>
        </div>

        <div class="pt-4 border-t border-gray-100">
          <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :current_password, autocomplete: "current-password",
            class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
          <p class="text-xs text-gray-500 mt-1">Required to save changes</p>
        </div>

        <%= f.submit "Save Changes", class: "w-full bg-season-green text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition" %>
      <% end %>

      <div class="mt-8 pt-6 border-t border-gray-100">
        <h2 class="text-lg font-semibold text-season-dark mb-4">Danger Zone</h2>
        <%= button_to "Cancel My Account", registration_path(resource_name), 
          data: { confirm: "Are you sure you want to delete your account?", turbo_confirm: "Are you sure?" }, 
          method: :delete,
          class: "w-full bg-red-50 text-red-600 py-3 rounded-xl font-medium hover:bg-red-100 transition" %>
      </div>
    </div>
  </div>
</div>
