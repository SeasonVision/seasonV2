<% content_for :title, "Sign In" %>

<div class="min-h-screen flex flex-col">
  <div class="fixed top-0 left-0 right-0 bg-season-cream px-4 py-3 flex items-center justify-between z-50">
    <a href="/">
      <img src="/icon.svg" class="h-10 w-auto" alt="Season">
    </a>
    <a href="/users/sign_up" class="px-4 py-2 text-sm font-medium bg-season-green text-white rounded-lg hover:bg-green-700">Sign Up</a>
  </div>

  <div class="flex-1 flex items-center justify-center px-6 pt-20 pb-8">
    <div class="w-full max-w-sm">
      <h1 class="text-2xl font-bold text-season-dark text-center mb-6">Welcome Back</h1>
      
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
            class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "w-4 h-4 text-season-green border-gray-300 rounded focus:ring-season-green" %>
            <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
          </div>
        <% end %>

        <%= f.submit "Sign In", class: "w-full bg-season-green text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition" %>
      <% end %>

      <div class="mt-6 text-center">
        <a href="/users/password/new" class="text-sm text-season-green hover:underline">Forgot your password?</a>
      </div>
    </div>
  </div>
</div>
