<% content_for :title, "Forgot Password" %>

<div class="min-h-screen flex flex-col">
  <nav class="fixed top-0 left-0 right-0 bg-season-cream px-4 py-3 flex items-center justify-between z-50">
    <%= link_to root_path do %>
      <img src="/icon.svg" class="h-10 w-auto" alt="Season">
    <% end %>
  </nav>

  <div class="flex-1 flex items-center justify-center px-6 pt-20 pb-8">
    <div class="w-full max-w-sm">
      <h1 class="text-2xl font-bold text-season-dark text-center mb-2">Forgot Password?</h1>
      <p class="text-gray-500 text-center mb-6">We'll send you a link to reset your password</p>
      
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-season-green focus:border-transparent outline-none transition" %>
        </div>

        <%= f.submit "Send Reset Link", class: "w-full bg-season-green text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition" %>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "Back to Sign In", new_session_path(resource_name), class: "text-sm text-season-green hover:underline" %>
      </div>
    </div>
  </div>
</div>
